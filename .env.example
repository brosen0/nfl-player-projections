# Copy to .env and fill in values. Never commit .env to git.
# Required only for optional features.

# ── Server ──
# PORT is injected by PaaS platforms (Render, Railway, Fly.io, Heroku).
# Locally, defaults to 8501 if not set.
# PORT=8501

# ── Email alerts (scripts/email_alerts.py) ──
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# ── Database ──
# Optional: PostgreSQL for database_migration.py (default is SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/nfl_predictor

# ── Vegas lines (The Odds API - https://the-odds-api.com) ──
# Free tier: 500 requests/month. Used for live/future game lines.
# Historical lines are loaded from nfl-data-py without an API key.
# VEGAS_API_KEY=

# ── SSL/certs (usually not needed; certifi is used by default) ──
# SSL_CERT_FILE=
# REQUESTS_CA_BUNDLE=
